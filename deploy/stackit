#
# stackit — drive the Sovereign Agentic OS on STACKIT from your Mac.
#
#   ./deploy/stackit on            # wake: scale the SKE node pool back up
#   ./deploy/stackit off           # sleep: scale the SKE node pool to 0 (overnight)
#   ./deploy/stackit status        # node pool + pod summary
#   ./deploy/stackit deploy        # full provision + GitOps deploy (⚠ real spend)
#   ./deploy/stackit destroy       # tear everything down (⚠ deletes managed data)
#   ./deploy/stackit urls          # the public tool hostnames
#   ./deploy/stackit open [tool]   # open a tool in the browser (default: the OS UI)
#   ./deploy/stackit schedule      # auto on 08:00 / off 20:00 every day (launchd)
#   ./deploy/stackit schedule 09:00 18:00 weekdays
#   ./deploy/stackit unschedule
#   ./deploy/stackit schedule-status
#
# MODE (Mode A self-hosted = DEFAULT). Append to deploy/destroy:
#   --self-hosted  Mode A — SKE cluster + DNS only; every backend bundled
#                  in-cluster. Pauses fully with the node pool (no 24/7 managed
#                  bill). Default; equivalently STACKIT_MODE=selfhosted.
#   --managed      Mode B — also provision the STACKIT managed services
#                  (Postgres Flex / OpenSearch / Object Storage / Secrets Manager
#                  / AI Model Serving), which bill 24/7. STACKIT_MODE=managed.
#   e.g.  ./deploy/stackit deploy --self-hosted
#
# on/off scale the SKE NODE POOL (compute) up/down — the daily cost window.
# In Mode A that pauses the WHOLE stack (everything is in-cluster); in Mode B the
# managed Postgres/OpenSearch/registry keep billing 24/7 (use `destroy` to stop
# all spend). Auth + variables come from deploy/.env.stackit (gitignored; copy
# .env.stackit.example) so both manual and scheduled runs authenticate.
set -euo pipefail

HERE="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"      # the deploy/ dir
SELF="$HERE/$(basename "${BASH_SOURCE[0]}")"
ENV_FILE="$HERE/.env.stackit"
LOG_DIR="$HERE/.stackit-logs"
PLIST_DIR="$HOME/Library/LaunchAgents"
LABEL_ON="com.datamasterclass.sovereign-os.on"
LABEL_OFF="com.datamasterclass.sovereign-os.off"

# Load STACKIT auth + config (SA key path, tfvars, the DNS domain) if present.
[ -f "$ENV_FILE" ] && { set -a; . "$ENV_FILE"; set +a; }

c(){ printf "\033[1;36m%s\033[0m\n" "$*"; }
ok(){ printf "\033[1;32m✔ %s\033[0m\n" "$*"; }
warn(){ printf "\033[1;33m! %s\033[0m\n" "$*"; }
die(){ printf "\033[1;31m✖ %s\033[0m\n" "$*" >&2; exit 1; }
mk(){ make -C "$HERE" "$@"; }

domain(){ # the apex DNS name: from env, else terraform output, else placeholder
  if [ -n "${STACKIT_DNS_NAME:-}" ]; then echo "$STACKIT_DNS_NAME"
  else (cd "$HERE/terraform" && terraform output -raw dns_name 2>/dev/null) || echo "<your-domain>"; fi
}

cmd_urls(){
  local d; d="$(domain)"
  c "Sovereign Agentic OS — STACKIT consoles (once ingress is up):"
  printf "  %-14s https://%s\n" "OS UI"        "os.$d"
  printf "  %-14s https://%s\n" "LiteLLM"      "litellm.$d"
  printf "  %-14s https://%s\n" "Langfuse"     "langfuse.$d"
  printf "  %-14s https://%s\n" "Superset"     "superset.$d"
  printf "  %-14s https://%s\n" "Forgejo"      "forgejo.$d"
  printf "  %-14s https://%s\n" "Argo CD"      "argocd.$d"
  printf "  %-14s https://%s\n" "OpenMetadata" "openmetadata.$d"
  [ "$d" = "<your-domain>" ] && warn "Set STACKIT_DNS_NAME in deploy/.env.stackit (or run after 'deploy')."
}

cmd_open(){
  local d t="${1:-os}"; d="$(domain)"
  [ "$d" = "<your-domain>" ] && die "No domain yet — set STACKIT_DNS_NAME in deploy/.env.stackit."
  open "https://$t.$d"
}

cmd_status(){
  if [ -f "$HERE/kubeconfig.yaml" ]; then
    KUBECONFIG="$HERE/kubeconfig.yaml" kubectl get nodes 2>/dev/null | sed 's/^/  /' || warn "cluster unreachable (asleep?)"
    echo
    KUBECONFIG="$HERE/kubeconfig.yaml" kubectl -n agentic-os get pods --no-headers 2>/dev/null | awk '{print $3}' | sort | uniq -c | sed 's/^/  /' || true
  else warn "No kubeconfig.yaml yet — run './deploy/stackit deploy' or 'make -C deploy kubeconfig'."; fi
}

# Resolve the deploy MODE. Precedence: explicit --self-hosted/--managed flag >
# STACKIT_MODE env > the mode persisted by the last `deploy` (.stackit-mode) >
# selfhosted (Mode A) default. Persisting the last deploy mode keeps on/off/destroy
# from flipping enable_managed_backends against a live cluster (which would try to
# destroy/recreate the managed services). Sets global $MODE; consumes the flag.
MODE_FILE="$HERE/.stackit-mode"
MODE="${STACKIT_MODE:-$([ -f "$MODE_FILE" ] && cat "$MODE_FILE" || echo selfhosted)}"
parse_mode(){
  local keep=()
  for a in "$@"; do
    case "$a" in
      --self-hosted|--selfhosted) MODE="selfhosted" ;;
      --managed)                  MODE="managed" ;;
      *) keep+=("$a") ;;
    esac
  done
  [ "$MODE" = "selfhosted" ] || [ "$MODE" = "managed" ] || die "MODE must be selfhosted|managed"
  PARSED_ARGS=("${keep[@]}")
}

confirm_spend(){
  local g; [ "$MODE" = "managed" ] && g="I-ACCEPT-MODE-B-COSTS" || g="I-ACCEPT-MODE-A-COSTS"
  [ "${CONFIRM:-}" = "$g" ] && return 0
  if [ "$MODE" = "managed" ]; then
    warn "Mode B: provisions STACKIT MANAGED services that bill 24/7 (~EUR 770-1,100/mo)."
  else
    warn "Mode A (self-hosted): provisions an SKE cluster + LB + DNS only — all backends"
    warn "run in-cluster and PAUSE with the node pool ('stackit off'). No 24/7 managed bill."
  fi
  read -r -p "Type '$g' to proceed: " a </dev/tty || true
  [ "$a" = "$g" ] || die "Aborted (no cost confirmation)."
  export CONFIRM="$g"
}

# ---- launchd scheduling ----------------------------------------------------
write_plist(){ # write_plist <label> <action> <hour> <minute> <weekday-or-empty>
  local label="$1" action="$2" hour="$3" min="$4" wd="${5:-}"
  mkdir -p "$PLIST_DIR" "$LOG_DIR"
  local wdblock=""; [ -n "$wd" ] && wdblock="    <key>Weekday</key><integer>$wd</integer>"
  # If weekdays requested, emit one StartCalendarInterval per Mon-Fri (1-5).
  local cal=""
  if [ "$wd" = "weekdays" ]; then
    for d in 1 2 3 4 5; do
      cal="$cal    <dict><key>Hour</key><integer>$hour</integer><key>Minute</key><integer>$min</integer><key>Weekday</key><integer>$d</integer></dict>\n"
    done
    cal="  <key>StartCalendarInterval</key>\n  <array>\n$cal  </array>"
  else
    cal="  <key>StartCalendarInterval</key>\n  <dict><key>Hour</key><integer>$hour</integer><key>Minute</key><integer>$min</integer></dict>"
  fi
  printf '%s\n' '<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>'"$label"'</string>
  <key>ProgramArguments</key>
  <array><string>'"$SELF"'</string><string>'"$action"'</string></array>
  <key>StandardOutPath</key><string>'"$LOG_DIR/$action.log"'</string>
  <key>StandardErrorPath</key><string>'"$LOG_DIR/$action.log"'</string>'"$(printf "\n$cal")"'
</dict></plist>' > "$PLIST_DIR/$label.plist"
  launchctl unload "$PLIST_DIR/$label.plist" 2>/dev/null || true
  launchctl load -w "$PLIST_DIR/$label.plist"
}

cmd_schedule(){
  local on="${1:-08:00}" off="${2:-20:00}" days="${3:-daily}" wd=""
  [ "$days" = "weekdays" ] && wd="weekdays"
  [[ "$on" =~ ^[0-2][0-9]:[0-5][0-9]$ && "$off" =~ ^[0-2][0-9]:[0-5][0-9]$ ]] || die "Use HH:MM HH:MM, e.g. 08:00 20:00"
  write_plist "$LABEL_ON"  on  "${on%%:*}"  "${on##*:}"  "$wd"
  write_plist "$LABEL_OFF" off "${off%%:*}" "${off##*:}" "$wd"
  ok "Scheduled: ON at $on, OFF at $off ($days). Logs: $LOG_DIR/"
  warn "launchd only fires while this Mac is awake. For an always-on schedule, use the in-cluster KEDA cron (see deploy/README)."
}

cmd_unschedule(){
  for l in "$LABEL_ON" "$LABEL_OFF"; do
    launchctl unload "$PLIST_DIR/$l.plist" 2>/dev/null || true
    rm -f "$PLIST_DIR/$l.plist"
  done
  ok "Schedule removed."
}

cmd_schedule_status(){
  for l in "$LABEL_ON" "$LABEL_OFF"; do
    if [ -f "$PLIST_DIR/$l.plist" ]; then ok "$l installed ($(launchctl list | grep -q "$l" && echo loaded || echo not-loaded))"; else warn "$l not installed"; fi
  done
}

usage(){ sed -n '5,/^set -euo pipefail/p' "$SELF" | sed '$d; s/^# \{0,1\}//'; }

case "${1:-help}" in
  on|wake)        parse_mode "$@"; c "Waking — scaling the SKE node pool up… (MODE=$MODE)"; mk wake MODE="$MODE" ;;
  off|sleep)      parse_mode "$@"; c "Sleeping — scaling the SKE node pool to 0… (MODE=$MODE)"; mk sleep MODE="$MODE" ;;
  status)         cmd_status ;;
  deploy|up)      parse_mode "$@"; confirm_spend; echo "$MODE" > "$MODE_FILE"; c "Provisioning + deploying via GitOps (MODE=$MODE)…"; mk stackit-up MODE="$MODE" GATE="$CONFIRM" ;;
  destroy|down)   parse_mode "$@"; confirm_spend; c "Tearing down (MODE=$MODE)…"; mk stackit-down MODE="$MODE" GATE="$CONFIRM"; rm -f "$MODE_FILE" ;;
  kubeconfig)     mk kubeconfig ;;
  urls)           cmd_urls ;;
  open)           shift; cmd_open "${1:-os}" ;;
  schedule)       shift; cmd_schedule "$@" ;;
  unschedule)     cmd_unschedule ;;
  schedule-status) cmd_schedule_status ;;
  help|-h|--help|*) usage ;;
esac

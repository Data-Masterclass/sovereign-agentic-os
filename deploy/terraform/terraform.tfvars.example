#
# Copy to terraform.tfvars (GITIGNORED) and fill in. terraform.tfvars is never
# committed. Secrets are NOT set here — credentials are provider-generated.

# --- Required ---------------------------------------------------------------
project_id = "00000000-0000-0000-0000-000000000000" # STACKIT project ID
dns_name   = "agentic-os.example.com"                # apex DNS name you control

# Path to the provisioning-scoped SA key (gitignored). Or unset and use the
# STACKIT_SERVICE_ACCOUNT_KEY_PATH env var / STACKIT CLI credentials.
service_account_key_path = "../../../stackit/sa-key.json"

# --- Region / naming (defaults shown) ---------------------------------------
region      = "eu01"
name_prefix = "dm-agentic-os"

# --- Mode toggle ------------------------------------------------------------
# The VERIFIED single-node path runs every backend IN-CLUSTER (self-hosted), so
# set Mode A. Mode B (managed) is wired but not the verified path and bills 24/7.
# false = Mode A — SKE cluster + DNS ONLY; all backends bundled in-cluster from
#                  the self-contained chart (pauses with the node pool). The
#                  CLI/Makefile also set this for you (`make stackit-up` /
#                  `stackit deploy --self-hosted` pass -var enable_managed_backends=false).
enable_managed_backends = false

# --- SKE cluster / Kubernetes -----------------------------------------------
# 1.31 (the old default) is REJECTED by SKE at apply — use 1.34.
kubernetes_version_min = "1.34"

# --- SKE node pool (VERIFIED single-node path) ------------------------------
# DEFAULT topology: ONE `m3i.16` worker (memory-optimized, gen-3 Intel; ~16 vCPU /
# 128 GB — confirm exact specs/price in the STACKIT calculator) in a SINGLE AZ,
# node pool pinned min=1/max=1. The full L1–L3 self-contained stack (CloudNativePG,
# OpenSearch, ClickHouse, Valkey, MinIO, Langfuse, Superset, OpenMetadata, Forgejo,
# Dagster, …) plus the in-box model AND central Trino run on this one node.
#
# Sizing decision (2026-06-29): central Trino is a memory-hungry, always-on JVM.
# Rather than add a dedicated 2nd Trino node we run ONE memory-optimized box —
# `m3i.16` gives Trino heap headroom and gen-3 Intel CPU for concurrent-query
# throughput — because cross-node pod networking on SKE-in-an-SNA is BROKEN (see
# below), a single bigger box is the only viable topology.
#
# ⚠ DO NOT add nodes / AZs. Cross-node pod networking on SKE-in-an-SNA is BROKEN
#   (pods on a node without a CoreDNS replica can't resolve DNS or reach pods on
#   other nodes — verified 100% cross-node loss; it took out CloudNativePG). One
#   node sidesteps it entirely. Multi-node / Mode-B stay overridable but BLOCKED.
# Confirm `m3i.16` exists in the STACKIT machine-type catalog for your project
# before apply (`c1.4` is deprecated).
node_machine_type   = "m3i.16"
node_pool_min       = 1
node_pool_max       = 1            # one AZ ⇒ max=1 (SKE needs max ≥ #AZs)
availability_zones  = ["eu01-1"]   # single AZ — a 1-node pool cannot span AZs
node_volume_size_gb = 50

# --- PostgreSQL Flex (MODE B only — ignored when enable_managed_backends=false) -
postgres_version  = "16"
postgres_flavor   = { cpu = 2, ram = 8 }
postgres_replicas = 1
postgres_storage  = { class = "premium-perf2-stackit", size = 20 }
# Tighten to the SKE egress CIDR at go-live (terraform output / stackit ske).
postgres_acl = ["0.0.0.0/0"]

# --- OpenSearch (MODE B only; confirm plan names: `stackit opensearch plans`) -
opensearch_plan_name = "stackit-opensearch-single-small"
opensearch_version   = "2"

# --- Container Registry (MODE B; manual — provider has no resource) ----------
container_registry_url = "REPLACE-registry-host/agentic-os"

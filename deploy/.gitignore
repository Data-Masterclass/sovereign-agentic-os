# Never commit Terraform state, vars, provider plugins, or cluster credentials.
terraform/.terraform/
terraform/.terraform.lock.hcl
terraform/*.tfstate
terraform/*.tfstate.*
terraform/*.tfvars
!terraform/*.tfvars.example
# Saved plan binaries embed resolved secret values — never commit.
terraform/tfplan
terraform/*.tfplan
terraform/crash.log
terraform/override.tf
terraform/override.tf.json
*.bak
kubeconfig.yaml
*.kubeconfig

# local control (stackit CLI)
.env.stackit
.stackit-logs/
.stackit-mode
values.stackit-deploy.yaml
# ingress basic-auth credential (htpasswd) — local secret, never commit
.basic-auth-cred

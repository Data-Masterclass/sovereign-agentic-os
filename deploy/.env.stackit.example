#
# Config + auth for ./deploy/stackit (used by both manual and scheduled runs).
# Copy this to  deploy/.env.stackit  and fill in your values.
# deploy/.env.stackit is GITIGNORED — never commit real credentials.

# --- STACKIT provider authentication (service-account key) -------------------
# Download a service-account key (JSON) from the STACKIT portal, store it OUTSIDE
# the repo, and point to it here. The terraform stackitcloud/stackit provider +
# the on/off/deploy commands authenticate with this.
export STACKIT_SERVICE_ACCOUNT_KEY_PATH="$HOME/.stackit/sa-key.json"
# (Alternative: export STACKIT_SERVICE_ACCOUNT_TOKEN="...")

# --- Deployment identity -----------------------------------------------------
# Your apex DNS name. The consoles live on subdomains: os./litellm./langfuse./
# superset./forgejo./argocd./openmetadata. of this. Used by `stackit urls|open`.
export STACKIT_DNS_NAME="agentic-os.example.eu"

# The rest (project_id, region=eu01, node pool flavor/size, dns_name) lives in
# deploy/terraform/terraform.tfvars — copy deploy/terraform/terraform.tfvars.example.
# Confirm the exact provider auth variables in deploy/README.md.
